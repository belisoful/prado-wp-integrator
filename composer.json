{
	"name": "belisoful/prado-wp-integrator",
	"type": "prado4-extension",
	"description": "Integrates Wordpress into PRADO",
	"keywords": [ "prado", "wordpress", "integration", "extension"],
	"homepage": "https://github.com/belisoful/prado-wp-integrator",
	"license": "MIT",
	"authors": [
		{
			"name": "Brad Anderson",
			"email": "belisoful@icloud.com",
			"role": "Software Engineer",
			"homepage": "https://github.com/belisoful"
		}
	],
	"autoload": {
		"psr-4": {
			"PradoWpIntegrator\\": "src"
		}
	},
	"repositories": [
		{
			"type": "composer",
			"url": "https://asset-packagist.org"
		}
	],
	"require": {
		"php": ">=7.4.0",
		"pradosoft/prado" : "^4.3",
		"johnpbloch/wordpress": "^6.9"
	},
	"require-dev" : {
		"phpunit/phpunit" : "^10",
		"phpdocumentor/shim": "^3",
		"friendsofphp/php-cs-fixer": "^3.94",
		"phpstan/phpstan": "^2.1",
		"php-stubs/wordpress-stubs": "*",
		"johnpbloch/wordpress": "*"
	},
	"config": {
		"platform": {
			"php": "8.1"
		},
		"allow-plugins": {
			"phpdocumentor/shim": true,
			"johnpbloch/wordpress-core-installer": true
		}
	},
	"scripts": {
		"unittest": "vendor/bin/phpunit --testsuite unit"
	},
	"extra": {
		"bootstrap": "PradoWpIntegrator\\WPIntegratorModule"
	}
}

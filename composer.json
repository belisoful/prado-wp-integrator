	"license": "MIT License",
	"type": "prado4-extension",
	"keywords": [ "prado", "wordpress", "integration", "extension"],
	"homepage": "https://github.com/belisoful/prado-wp-integrator",
	"authors": [
		{
			"name": "Brad Anderson",
			"email": "belisoful@icloud.com",
			"role": "Software Engineer",
			"homepage": "https://github.com/belisoful"
		}
